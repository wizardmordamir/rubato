{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    // Resolve cursedbelt to its TS SOURCE via its `source` export condition (matches
    // ui/vite.config.ts's resolve.conditions) instead of a non-existent ./dist. Covers
    // every cursedbelt subpath through its exports map — no per-subpath paths to drift.
    // tsconfig.lib.json extends this, so it inherits customConditions too.
    "customConditions": ["source"],
    // Dedupe React's types so cursedbelt's source files (consumed via the `source`
    // condition) resolve react/react-dom from ru-ui's single @types/react copy.
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["../src/shared/*"],
      "react": ["./node_modules/@types/react"],
      "react/jsx-runtime": ["./node_modules/@types/react/jsx-runtime"],
      "react-dom": ["./node_modules/@types/react-dom"],
      "@tanstack/react-query": ["./node_modules/@tanstack/react-query"],
      "recharts": ["./node_modules/recharts"],
      // glide-data-grid lives in ui/node_modules; dedupe its types so cursedbelt
      // source (resolved via the `source` export condition) uses the same copy.
      "@glideapps/glide-data-grid": ["./node_modules/@glideapps/glide-data-grid"]
    },
    "types": []
  },
  "include": ["src", "vite.config.ts"]
}
