{
  "name": "rubato",
  "version": "1.0.0",
  "description": "Personal toolbox of TypeScript dev scripts and API helpers, run with bun.",
  "type": "module",
  "bin": {
    "rubato-setup": "./dist/scripts/setup-aliases.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./api": "./dist/api.js",
    "./jenkins": "./dist/jenkins.js",
    "./quay": "./dist/quay.js",
    "./gitlab": "./dist/gitlab.js",
    "./splunk": "./dist/splunk.js",
    "./datadog": "./dist/datadog.js",
    "./dynatrace": "./dist/dynatrace.js",
    "./github": "./dist/github.js",
    "./rancher": "./dist/rancher.js",
    "./openshift": "./dist/openshift.js",
    "./harness": "./dist/harness.js",
    "./deploy": "./dist/deploy.js",
    "./git": "./dist/git.js",
    "./apps": "./dist/apps.js",
    "./config": "./dist/config.js",
    "./output": "./dist/output.js",
    "./automation": "./dist/automation.js",
    "./tools": "./dist/tools.js",
    "./request": "./dist/request.js",
    "./orchestration": "./dist/orchestration.js",
    "./server": "./dist/server.js",
    "./plugins/automations": "./dist/plugins__automations.js",
    "./styles.css": "./styles.css",
    "./ui/shell": {
      "types": "./ui/dist-lib/ui/src/shell/index.d.ts",
      "import": "./ui/dist-lib/shell.js"
    },
    "./ui/automations": {
      "types": "./ui/dist-lib/ui/src/pages/Automations/index.d.ts",
      "import": "./ui/dist-lib/automations.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "ui/dist",
    "ui/dist-lib",
    "src/shared",
    "styles.css"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wizardmordamir/rubato.git"
  },
  "scripts": {
    "biome": "bun x biome check --write --unsafe ./src",
    "format": "bun x biome format --write ./src",
    "lint": "bun x biome lint --write --unsafe ./src",
    "tsc": "tsc --noEmit",
    "test": "bun test",
    "test:report": "bun run scripts/testReport.ts",
    "done": "bun run scripts/done.ts",
    "e2e": "bun x playwright test -c e2e/playwright.config.ts",
    "e2e:grep": "bun x playwright test -c e2e/playwright.config.ts -g",
    "setup": "bun run scripts/setup.ts",
    "update": "bun update --latest",
    "serve": "bun --hot run src/scripts/serve.ts",
    "dev": "bun run scripts/dev.ts",
    "web:dev": "cd ui && bun run dev",
    "web:build": "bun scripts/buildCache check ui || (cd ui && bun install && bun run build && bun run build:lib && cd .. && bun scripts/buildCache save ui)",
    "build:lib": "cd ui && bun run build:lib",
    "clean": "bun scripts/withTimeout 3000 rm -rf dist ui/dist && bun scripts/buildCache clean",
    "build": "bun run scripts/build.ts",
    "prepublishOnly": "bun run tsc && bun run test && bun run web:build && bun run build"
  },
  "keywords": [
    "scripts",
    "tools",
    "cli"
  ],
  "license": "ISC",
  "dependencies": {
    "cwip": "^2.0.1",
    "exceljs": "^4.4.0",
    "hyperformula": "^3.3.0",
    "yaml": "^2.9.0"
  },
  "peerDependencies": {
    "@huggingface/transformers": "^4.2.0",
    "playwright": "^1.60.0",
    "xlsx": "^0.18.0"
  },
  "peerDependenciesMeta": {
    "@huggingface/transformers": {
      "optional": true
    },
    "playwright": {
      "optional": true
    },
    "xlsx": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@huggingface/transformers": "^4.2.0",
    "@playwright/test": "^1.60.0",
    "@types/bun": "^1.3.13",
    "playwright": "^1.60.0",
    "typescript": "^6.0.3",
    "unpdf": "^1.6.2"
  }
}
